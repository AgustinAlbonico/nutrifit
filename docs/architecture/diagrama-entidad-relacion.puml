usuario ||--o{ notificacion : "1:N"
usuario ||--o{ usuario_grupo_permiso : "1:N"
usuario ||--o{ usuario_accion : "1:N"
usuario ||--o{ adjunto_clinico : "1:N"
usuario ||--o{ ficha_salud_version : "1:N"

