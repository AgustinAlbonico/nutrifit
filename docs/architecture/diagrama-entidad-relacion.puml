' FICHA SALUD
ficha_salud ||--o{ ficha_salud_version : "1:N"
ficha_salud ||--o{ ficha_salud_patologia : "1:N"
ficha_salud ||--o{ ficha_salud_alergia : "1:N"
patologia ||--o{ ficha_salud_patologia : "1:N"
alergia ||--o{ ficha_salud_alergia : "1:N"

' PLAN ALIMENTACION
plan_alimentacion ||--o{ dia_plan : "1:N"
dia_plan ||--o{ opcion_comida : "1:N"
opcion_comida ||--o{ item_comida : "1:N"
item_comida }o--|| alimento : "N:1"
