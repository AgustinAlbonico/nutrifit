# NutriFit Supervisor Backend
# Copiar este archivo a .env para desarrollo local.
# No usar secretos reales en este archivo.

# App
PORT=3000
APP_NAME=NutriFit
NODE_ENV=dev
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Base de datos MySQL
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=nutrifit_supervisor
DATABASE_USER=root
DATABASE_PASSWORD=root

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# MinIO / almacenamiento de archivos
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=nutrifit-fotos-perfil

# IA / proveedores de modelos
# AI_PROVIDER_CHAIN: orden de los proveedores que se intentan en cascada.
# Si una llamada falla por 429 / timeout / 5xx se salta al siguiente.
# Valores validos: groq, gemini, openrouter. Default: groq,gemini,openrouter.
# Groq sigue siendo el principal mientras tenga creditos.
AI_PROVIDER_CHAIN=groq,gemini,openrouter

# Groq (https://console.groq.com) - por defecto, requerido para IA.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (https://aistudio.google.com/apikey) - opcional.
# Si esta vacio y el provider chain lo nombra, se omite.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# OpenRouter (https://openrouter.ai/keys) - opcional, modelos free disponibles.
# Si esta vacio y el provider chain lo nombra, se omite.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.3-8b-instruct:free

# Email / SMTP
# Si SMTP_HOST queda vacio, EmailModule usa ConsoleEmailProvider y solo loguea emails.
# Para SMTP real configurar host, puerto, secure, usuario, password y remitente.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@nutrifit.local

# Jobs / schedulers
# AUSENCIA_UMBRAL_MINUTOS: minutos de tolerancia antes de marcar ausencia.
# REMINDERS_CRON_EXPR: cron de recordatorios de turnos, default runtime "0 * * * *".
# ALIMENTOS_SYNC_HABILITADO: true/1/si habilita sync automatica de alimentos.
AUSENCIA_UMBRAL_MINUTOS=15
REMINDERS_CRON_EXPR="0 * * * *"
ALIMENTOS_SYNC_HABILITADO=false
