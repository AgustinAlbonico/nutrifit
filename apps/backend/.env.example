# NutriFit Supervisor Backend
# Copiar este archivo a .env para desarrollo local.
# No usar secretos reales en este archivo.

# App
PORT=3000
APP_NAME=NutriFit
NODE_ENV=dev
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Base de datos MySQL
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=nutrifit_supervisor
DATABASE_USER=root
DATABASE_PASSWORD=root

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# MinIO / almacenamiento de archivos
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=nutrifit-fotos-perfil

# IA / proveedores de modelos
# AI_PROVIDER_CHAIN: orden de los proveedores que se intentan en cascada.
# Si una llamada falla por 429 / timeout / 5xx se salta al siguiente.
# Valores validos: groq, gemini, opencode, openrouter.
# Default: opencode,groq,gemini,openrouter (OpenCode Zen como principal).
AI_PROVIDER_CHAIN=opencode,groq,gemini,openrouter

# === Groq ============================================================
# URL de la consola: https://console.groq.com
# Como sacar la API key:
#   1. Entrar a https://console.groq.com y crear cuenta / iniciar sesion.
#   2. Menu lateral "API Keys" -> "Create API Key".
#   3. Ponerle un nombre (ej. "nutrifit-dev") y crear.
#   4. Copiar el valor (empieza con "gsk_") y pegarlo en GROQ_API_KEY.
# Requerido para IA. Tier free: cuota por RPM/RPD.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# === Google Gemini ===================================================
# URL: https://aistudio.google.com/app/apikey
# Como sacar la API key:
#   1. Ir a https://aistudio.google.com/app/apikey con cuenta Google.
#   2. "Create API key" -> elegir o crear proyecto de GCP si lo pide.
#   3. Copiar el valor y pegarlo en GEMINI_API_KEY.
# Opcional: si esta vacio y el provider chain lo nombra, se omite.
# Tier free: limites por modelo (RPD/RPM).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# === OpenCode Zen (PRINCIPAL) ========================================
# URL: https://opencode.ai/zen
# Como sacar la API key:
#   1. Ir a https://opencode.ai/zen y crear cuenta / iniciar sesion.
#   2. En el dashboard, generar el API key (Bearer token).
#   3. Copiar el valor y pegarlo en OPENCODE_API_KEY.
# API OpenAI-compatible. Modelos con sufijo "-free" no consumen creditos.
# Lista de modelos disponibles: GET https://opencode.ai/zen/v1/models
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_MODEL=deepseek-v4-flash-free

# === OpenRouter ======================================================
# URL: https://openrouter.ai/keys
# Como sacar la API key:
#   1. Ir a https://openrouter.ai/ y crear cuenta / iniciar sesion.
#   2. Menu "Keys" -> "Create Key".
#   3. Ponerle un nombre y opcionalmente un limite de credito.
#   4. Copiar el valor (empieza con "sk-or-") y pegarlo en OPENROUTER_API_KEY.
# Opcional: tiene modelos free (sufijo ":free") y de pago.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.3-8b-instruct:free

# Email / SMTP
# Si SMTP_HOST queda vacio, EmailModule usa ConsoleEmailProvider y solo loguea emails.
# Para SMTP real configurar host, puerto, secure, usuario, password y remitente.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@nutrifit.local

# Jobs / schedulers
# AUSENCIA_UMBRAL_MINUTOS: minutos de tolerancia antes de marcar ausencia.
# REMINDERS_CRON_EXPR: cron de recordatorios de turnos, default runtime "0 * * * *".
# ALIMENTOS_SYNC_HABILITADO: true/1/si habilita sync automatica de alimentos.
AUSENCIA_UMBRAL_MINUTOS=15
REMINDERS_CRON_EXPR="0 * * * *"
ALIMENTOS_SYNC_HABILITADO=false
# IA config encryption. Generá con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IA_CONFIG_ENCRYPTION_KEY=
